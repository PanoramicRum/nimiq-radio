# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000
NODE_ENV=development

# Where transcoded MP3s are written (served at /static/tracks/<id>.mp3)
TRACKS_DIR=/tmp/radio-tracks

# CORS origin for the SPA. "*" for local dev; lock to the Nimiq Pay origin in prod.
CORS_ORIGIN=*

# ── Media pipeline (Phase 1) ─────────────────────────────────────────────
# yt-dlp binary (inside the Docker image it's on PATH as "yt-dlp")
YTDLP_BIN=yt-dlp
MAX_DURATION_SEC=1200         # download cap (20 min); must be >= MAX_SONG_SEC
MAX_FILESIZE=100M             # yt-dlp --max-filesize
AUDIO_FORMAT=m4a              # native container: downloads audio-only AAC and copies it (no re-encode)
AUDIO_BITRATE=192K            # only used on the rare re-encode fallback
DOWNLOAD_CONCURRENCY=2        # p-queue concurrency
DOWNLOAD_TIMEOUT_MS=120000    # hard kill the yt-dlp process group after this

# Datacenter-IP hardening (required when deployed on a cloud VM).
# bgutil PO-token provider base URL (the sidecar in docker-compose).
PO_TOKEN_BASE_URL=http://bgutil:4416
# yt-dlp player clients. "default" exposes audio-only m4a (fast download); web_safari,tv kept as a fallback chain.
PLAYER_CLIENT=default,web_safari,tv
# Path to a Netscape-format cookies.txt from a throwaway account (optional but
# recommended on datacenter IPs). Left empty = no cookies.
COOKIES_FILE=

# ── Song metadata fingerprint + content gate (Phase 7) ──
# AcoustID API key (register a free app at https://acoustid.org/new-application).
# Unset = fingerprinting disabled, metadata falls back to yt-dlp (uploader-as-artist).
ACOUSTID_API_KEY=
FPCALC_BIN=fpcalc
ACOUSTID_MIN_SCORE=0.5
ACOUSTID_TIMEOUT_MS=8000
FPCALC_TIMEOUT_MS=20000
# Content gate: reject non-songs (podcasts/talks/live) before downloading.
CONTENT_GATE_ENABLED=true
GATE_REQUIRE_MUSIC_CATEGORY=true
MIN_SONG_SEC=45
MAX_SONG_SEC=1200          # 20 min; must be <= MAX_DURATION_SEC

# ── Album cover art ──────────────────────────────────────────────────────
# Best-effort: Cover Art Archive (via the AcoustID release-group MBID) -> yt-dlp thumbnail fallback.
COVER_ENABLED=true
COVER_SIZE=500             # Cover Art Archive front-<N>: 250 | 500 | 1200
COVER_TIMEOUT_MS=6000
COVER_MAX_BYTES=5242880    # 5 MiB

# ── Nimiq payments (Phase 3 — not used yet) ──────────────────────────────
# NIMIQ_NETWORK=testnet        # testnet | mainnet
# RPC_URL=https://rpc.nimiq-testnet.com
# RECIPIENT_ADDRESS=NQ.. .... .... .... .... .... .... ....
# MIN_CONFIRMATIONS=10
